# ─── Next.js (`.env.local`) ───────────────────────────────────────────────────

NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Convex deployment (Dashboard → Settings → Environment Variables
#     or `npx convex env set KEY value`) ─────────────────────────────────────

# Required for Better Auth + JWT (same value you use when generating locally):
#   npx convex env set BETTER_AUTH_SECRET "$(openssl rand -base64 32)"
# BETTER_AUTH_SECRET=

# Must match the public URL users use to open this site (production domain in prod):
#   npx convex env set SITE_URL "http://localhost:3000"
# SITE_URL=http://localhost:3000

# Comma-separated staff emails that may access /admin (checked inside Convex):
#   npx convex env set ADMIN_EMAILS "person1@school.om,person2@school.om"
# ADMIN_EMAILS=

# Optional: secret for internal promotion mutation `internal:profiles:grantStaffRole`
#   npx convex env set STAFF_ROLE_SETUP_SECRET "$(openssl rand -hex 24)"
# STAFF_ROLE_SETUP_SECRET=

# Better Auth Infrastructure (Analytics / “Enrolment application” in the dashboard)
# Add the key from the dashboard, then restart `next dev` / redeploy.
# (This is read by the Infra client; the server `dash()` plugin is not in Convex
# because that package does not bundle for Convex’s JS runtime today.)
# BETTER_AUTH_API_KEY=ba_...
# Optional (defaults are usually correct):
# BETTER_AUTH_API_URL=
# BETTER_AUTH_KV_URL=
